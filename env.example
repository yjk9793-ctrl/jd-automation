# LLM Provider Configuration
# Choose one provider and set its API key

# OpenAI (Default)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude (Alternative)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Provider Selection
LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database (Optional - for data persistence)
# DATABASE_URL=postgresql://username:password@localhost:5432/jd_automation

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,txt,md,docx

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000

# Email Service Configuration (for PDF export)
# Choose one email service and configure it

# SendGrid (Recommended for production)
# SENDGRID_API_KEY=your_sendgrid_api_key
# FROM_EMAIL=noreply@yourdomain.com

# AWS SES (Amazon Simple Email Service)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# FROM_EMAIL=noreply@yourdomain.com

# Resend (Modern email API)
# RESEND_API_KEY=your_resend_api_key
# FROM_EMAIL=noreply@yourdomain.com

# SMTP (Generic SMTP server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# FROM_EMAIL=your_email@gmail.com

# Note: In demo mode, email sending is simulated without actual email delivery
